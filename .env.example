DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Auth.js — generate with: npx auth secret
AUTH_SECRET=your_generated_auth_secret
AUTH_URL=http://localhost:3000

# Admin + sample vendor seeding (used only by prisma/seed.ts, never by the app)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Ghoomora Admin
SEED_VENDOR_PASSWORD=change_me_strong_password

# OpenRouteService (free tier) — route visualization
ORS_API_KEY=your_ors_api_key

# App URL for metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary (optional — image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI (Phase 6 — optional)
GROQ_API_KEY=your_groq_api_key

# Pusher (Phase 6 — optional, live tracking)
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2

# Neon DATABASE_URL: use sslmode=verify-full (or sslmode=require — normalized at runtime in lib/pg-connection.ts)
