DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_CLERK_TELEMETRY_DISABLED=1
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Admin role assignment (comma-separated normalized emails)
ADMIN_EMAILS=admin@example.com

# OpenRouteService (free tier) — route visualization
ORS_API_KEY=your_ors_api_key

# App URL for metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary (optional — image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI (Phase 6 — optional)
GROQ_API_KEY=your_groq_api_key

# Pusher (Phase 6 — optional, live tracking)
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2

# Neon DATABASE_URL: use sslmode=verify-full (or sslmode=require — normalized at runtime in lib/pg-connection.ts)
