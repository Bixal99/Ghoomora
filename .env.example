# Local development — PostgreSQL via pgAdmin (or any local Postgres)
DATABASE_URL="postgresql://postgres:ChangeMe123!@localhost:5432/ghoomora"

# Production (Vercel): set DATABASE_URL in the host dashboard.
# Can be Neon or any Postgres-compatible provider — no code change needed either way.

# Auth.js — generate with: npx auth secret
AUTH_SECRET=your_generated_auth_secret
AUTH_URL=http://localhost:3000
# Session lengths (days). Remember-me sets cookie Max-Age; unchecked uses the shorter DB Session.expires.
AUTH_REMEMBER_ME_MAX_AGE_DAYS=30
AUTH_DEFAULT_MAX_AGE_DAYS=1

# Google OAuth (optional — without these, Continue with Google is hidden)
# Create an OAuth client in Google Cloud Console. Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email (Resend) — password reset + sign-up OTP
# Without RESEND_API_KEY / EMAIL_FROM, codes and reset links are logged to the server console.
#
# Test sender (onboarding@resend.dev):
#   Resend only delivers to the email on your Resend account.
#   Signups to any other address fall back to the npm run dev terminal: [email-otp] OTP for …
#
# Production:
#   Verify a domain at https://resend.com/domains
#   Set EMAIL_FROM to e.g. Ghoomora <noreply@yourdomain.com>
RESEND_API_KEY=
EMAIL_FROM=Ghoomora <onboarding@resend.dev>

# Admin bootstrap (used only by `npm run admin:create`, never by the app)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Ghoomora Admin

# OpenRouteService (free tier) — route visualization
ORS_API_KEY=your_ors_api_key

# App URL for metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary (optional — image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI (Phase 6 — optional)
GROQ_API_KEY=your_groq_api_key

# Pusher (Phase 6 — optional, live tracking)
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2
